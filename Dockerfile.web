FROM rust:slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libasound2-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Install wasm-pack
RUN curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh

WORKDIR /app
COPY . .

# Build the WASM package
RUN cd marathon-web && wasm-pack build --target web --out-dir static/pkg 2>&1

# ─── Serve stage ────────────────────────────────────────────────────────────
FROM nginx:alpine AS serve

# Copy built WASM files and static assets
COPY --from=builder /app/marathon-web/static /usr/share/nginx/html

# nginx config for WASM MIME types and game data
RUN cat > /etc/nginx/conf.d/default.conf << 'NGINX'
server {
    listen 80;
    root /usr/share/nginx/html;
    index index.html;

    # WASM needs correct MIME type
    types {
        application/wasm wasm;
        application/javascript js mjs;
        text/html html;
        text/css css;
    }

    # Enable gzip for large assets
    gzip on;
    gzip_types application/wasm application/javascript application/octet-stream;
    gzip_min_length 1000;

    # Game data files
    location /data/ {
        alias /data/;
        add_header Access-Control-Allow-Origin *;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
NGINX

EXPOSE 80
